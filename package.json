{
  "name": "estoque-solidario",
  "version": "1.0.0",
  "description": "Sistema de Controle de Doações - Projeto Extensionista",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "pkg . --targets node18-win-x64 --output EstoqueSolidario.exe"
  },
  "pkg": {
    "scripts": [
      "node_modules/sqlite3/lib/*.js"
    ],
    "assets": [
      "public/**/*",
      "node_modules/sqlite3/lib/binding/**/*.node"
    ]
  },
  "dependencies": {
    "express": "^4.18.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6"
  }
}